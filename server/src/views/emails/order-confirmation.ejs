<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <style>
    @media only screen and (max-width: 480px) {
      .body-table { width: 100% !important; }
      .content-pad { padding: 16px !important; }
      .header-pad { padding: 16px !important; }
      .body-pad { padding: 16px !important; }
      .info-table td { display: block !important; width: 100% !important; padding: 3px 0 !important; }
      .info-table td:first-child { padding-bottom: 0 !important; }
      .prod-table th, .prod-table td { padding: 8px 6px !important; font-size: 12px !important; }
      .prod-table th:nth-child(2), .prod-table td:nth-child(2),
      .prod-table th:nth-child(3), .prod-table td:nth-child(3) { display: none !important; }
      .prod-table .mobile-price { display: block !important; }
      .total-text { font-size: 16px !important; }
      .badge { font-size: 10px !important; padding: 2px 8px !important; }
      .summary-row { text-align: left !important; }
    }
    .prod-table .mobile-price { display: none; }
  </style>
</head>
<body style="margin: 0; padding: 0; font-family: Arial, sans-serif; background: #f4f4f4;">
  <table class="body-table" style="width: 100%; max-width: 600px; margin: 0 auto; background: #fff;" cellpadding="0" cellspacing="0">
    <tr>
      <td class="header-pad" style="background: #2563eb; padding: 24px 24px; text-align: center;">
        <h1 style="color: #fff; margin: 0; font-size: 20px;">HÓA ĐƠN BÁN HÀNG</h1>
        <p style="color: #93c5fd; margin: 4px 0 0; font-size: 13px;">Sport Nexus</p>
      </td>
    </tr>
    <tr>
      <td class="content-pad" style="padding: 24px;">
        <p style="font-size: 14px; color: #333; margin: 0 0 4px;">Xin chào <strong><%= full_name %></strong>,</p>
        <p style="font-size: 13px; color: #555; margin: 0 0 16px;">Cảm ơn bạn đã đặt hàng tại Sport Nexus.</p>

        <table style="width: 100%; background: #f9fafb; border-radius: 6px; padding: 12px; font-size: 13px; border-collapse: collapse; margin: 12px 0;">
          <tr><td style="padding: 3px 0; color: #64748b; width: 40%;">Số hóa đơn</td><td style="padding: 3px 0; color: #333; font-weight: bold;">#<%= order.id %></td></tr>
          <tr><td style="padding: 3px 0; color: #64748b;">Khách hàng</td><td style="padding: 3px 0; color: #333;"><%= full_name %></td></tr>
          <tr><td style="padding: 3px 0; color: #64748b;">Email</td><td style="padding: 3px 0; color: #333;"><%= order.user_email %></td></tr>
          <tr><td style="padding: 3px 0; color: #64748b;">Ngày đặt</td><td style="padding: 3px 0; color: #333;"><%= order.created_at ? new Date(order.created_at).toLocaleString('vi-VN') : '---' %></td></tr>
          <tr><td style="padding: 3px 0; color: #64748b;">Địa chỉ</td><td style="padding: 3px 0; color: #333;"><%= shipping_address %></td></tr>
        </table>

        <table style="width: 100%; background: #f9fafb; border-radius: 6px; padding: 12px; font-size: 13px; border-collapse: collapse; margin: 12px 0;">
          <tr>
            <td style="padding: 3px 0; color: #64748b; width: 40%;">Trạng thái</td>
            <td style="padding: 3px 0;">
              <span class="badge" style="display: inline-block; padding: 2px 10px; border-radius: 10px; font-size: 11px; font-weight: bold; background: #dbeafe; color: #1d4ed8;"><%= status_label %></span>
            </td>
          </tr>
          <tr>
            <td style="padding: 3px 0; color: #64748b;">Thanh toán</td>
            <td style="padding: 3px 0; color: #333;"><%= payment_method %></td>
          </tr>
          <tr>
            <td style="padding: 3px 0; color: #64748b;">TT thanh toán</td>
            <td style="padding: 3px 0;">
              <span class="badge" style="display: inline-block; padding: 2px 10px; border-radius: 10px; font-size: 11px; font-weight: bold; background: <%= payment_status === 'Paid' ? '#dcfce7' : '#fef3c7' %>; color: <%= payment_status === 'Paid' ? '#16a34a' : '#d97706' %>;"><%= payment_status_label %></span>
            </td>
          </tr>
        </table>

        <h3 style="font-size: 14px; color: #333; margin: 20px 0 8px;">Chi tiết sản phẩm</h3>
        <table class="prod-table" style="width: 100%; border-collapse: collapse; font-size: 13px;">
          <thead>
            <tr style="background: #f1f5f9;">
              <th style="padding: 8px 10px; text-align: left; color: #475569;">Sản phẩm</th>
              <th style="padding: 8px 10px; text-align: center; color: #475569;">SL</th>
              <th style="padding: 8px 10px; text-align: right; color: #475569;">Đơn giá</th>
              <th style="padding: 8px 10px; text-align: right; color: #475569;">Thành tiền</th>
            </tr>
          </thead>
          <tbody>
            <% items.forEach(function(item) { %>
            <% var pv = item.product_variant; %>
            <% var pname = pv?.product?.name || 'Sản phẩm #' + item.product_variant_id; %>
            <% var attrs = pv?.VariableAttributes || []; %>
            <% var attrText = attrs.map(function(a) { return a.attributeKey?.name + ': ' + a.value; }).join(' | '); %>
            <tr style="border-bottom: 1px solid #e2e8f0;">
              <td style="padding: 8px 10px; color: #333; font-size: 13px;">
                <strong><%= pname %></strong>
                <span class="mobile-price" style="display: none; color: #555; font-weight: normal;">
                  x<%= item.quantity %> — <%= formatPrice(item.price_at_purchase * item.quantity) %>
                </span>
                <% if (attrText) { %><br><span style="font-size: 11px; color: #888;"><%= attrText %></span><% } %>
              </td>
              <td style="padding: 8px 10px; text-align: center; color: #555; white-space: nowrap;"><%= item.quantity %></td>
              <td style="padding: 8px 10px; text-align: right; color: #555; white-space: nowrap;"><%= formatPrice(item.price_at_purchase) %></td>
              <td style="padding: 8px 10px; text-align: right; color: #333; font-weight: bold; white-space: nowrap;"><%= formatPrice(item.price_at_purchase * item.quantity) %></td>
            </tr>
            <% }); %>
          </tbody>
        </table>

        <table style="width: 100%; margin-top: 12px; border-top: 2px solid #e2e8f0;">
          <tr>
            <td style="padding: 8px 0 2px; font-size: 13px; color: #555; text-align: right;">
              Tạm tính: <strong><%= formatPrice(order.total_amount) %></strong>
            </td>
          </tr>
          <% if (order.discount_amount > 0) { %>
          <tr>
            <td style="padding: 2px 0; font-size: 13px; color: #16a34a; text-align: right;">
              Giảm giá: -<strong><%= formatPrice(order.discount_amount) %></strong>
            </td>
          </tr>
          <% } %>
          <tr>
            <td style="padding: 6px 0 0; border-top: 1px solid #e2e8f0;">
              <p class="total-text" style="margin: 0; font-size: 17px; color: #dc2626; font-weight: bold; text-align: right;">
                Tổng cộng: <%= formatPrice(order.final_amount) %>
              </p>
            </td>
          </tr>
        </table>

        <p style="font-size: 12px; color: #888; margin-top: 20px; padding-top: 12px; border-top: 1px solid #e2e8f0;">
          Chúng tôi sẽ liên hệ sớm nhất để xác nhận và giao hàng. Nếu có thắc mắc, vui lòng trả lời email này.
        </p>
        <p style="font-size: 12px; color: #888;">Trân trọng,<br><strong>Sport Nexus</strong></p>
      </td>
    </tr>
  </table>
</body>
</html>
